{
  "name": "Discriminated Unions Playground",
  "image": "mcr.microsoft.com/dotnet/nightly/sdk:11.0-preview",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "10.0",
      "installUsingAptGet": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "rust-lang.rust-analyzer"
      ],
      "settings": {
        "dotnet.server.useOmnisharp": false
      }
    }
  }
}